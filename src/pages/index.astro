---
import Layout from '../layouts/Layout.astro'

const PHONE = '634 358 045'
const PHONE_HREF = 'tel:+34634358045'
const WA_URL = 'https://wa.me/34634358045?text=Hola%2C%20necesito%20reparar%20un%20electrodom%C3%A9stico%20en%20Pamplona'

const MARCAS_DEST = [
  { nombre: 'Siemens', logo: '/logos/siemens.svg' },
  { nombre: 'Bosch',   logo: '/logos/bosch.svg' },
  { nombre: 'Balay',   logo: '/logos/balay.svg' },
]
const MARCAS_RESTO = [
  { nombre: 'Fagor',      favicon: 'fagor.com' },
  { nombre: 'Miele',      favicon: 'miele.com' },
  { nombre: 'AEG',        favicon: 'aeg.com' },
  { nombre: 'Electrolux', favicon: 'electrolux.com' },
  { nombre: 'Samsung',    favicon: 'samsung.com' },
  { nombre: 'LG',         favicon: 'lg.com' },
  { nombre: 'Zanussi',    favicon: 'zanussi.com' },
  { nombre: 'Teka',       favicon: 'teka.com' },
  { nombre: 'Beko',       favicon: 'beko.com' },
]

const SERVICIOS = [
  { nombre: 'Lavadoras', desc: 'No centrifuga, pierde agua, hace ruido, no enciende', icon: 'M4 6h16v2H4zm0 5h16v2H4zm0 5h16v2H4z' },
  { nombre: 'Frigoríficos', desc: 'No enfría, acumula hielo, gotea, hace ruido', icon: 'M18 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V4a2 2 0 0 0-2-2zM6 4h12v9H6V4zm0 11h12v5H6v-5z' },
  { nombre: 'Lavavajillas', desc: 'No lava bien, no desagua, no cierra, hace ruido', icon: 'M3 6h18v2H3V6zm0 5h18v2H3v-2zm0 5h18v2H3v-2z' },
  { nombre: 'Hornos', desc: 'No calienta, pantalla rota, no enciende, humo', icon: 'M20 3H4a1 1 0 0 0-1 1v2a1 1 0 0 0 1 1h16a1 1 0 0 0 1-1V4a1 1 0 0 0-1-1zm1 5H3v11a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V8zm-9 9H8v-2h4v2zm5 0h-2v-2h2v2zM8 13H6v-2h2v2zm5 0h-4v-2h4v2zm4 0h-2v-2h2v2z' },
  { nombre: 'Secadoras', desc: 'No seca, se para sola, hace ruido extraño', icon: 'M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm0 18c-4.42 0-8-3.58-8-8s3.58-8 8-8 8 3.58 8 8-3.58 8-8 8zm0-14c-3.31 0-6 2.69-6 6s2.69 6 6 6 6-2.69 6-6-2.69-6-6-6zm0 10c-2.21 0-4-1.79-4-4s1.79-4 4-4 4 1.79 4 4-1.79 4-4 4z' },
  { nombre: 'Placas', desc: 'Zona que no funciona, error en pantalla, no detecta', icon: 'M3 3h18v18H3V3zm2 2v14h14V5H5zm2 2h10v2H7V7zm0 4h10v2H7v-2zm0 4h7v2H7v-2z' },
  { nombre: 'Campanas', desc: 'Motor roto, luz fundida, no extrae, hace ruido', icon: 'M3 18l9-15 9 15H3zm9-11L5.5 17h13L12 7z' },
  { nombre: 'Congeladores', desc: 'No congela, acumula hielo, gotea, hace ruido', icon: 'M12 2l3 6H9l3-6zm0 20l-3-6h6l-3 6zM2 12l6-3v6L2 12zm20 0l-6 3V9l6 3zM5.64 5.64l4.95 1.77-1.77 4.95-4.95-1.77 1.77-4.95zm12.72 12.72l-4.95-1.77 1.77-4.95 4.95 1.77-1.77 4.95zm-12.72 0l-1.77-4.95 4.95-1.77 1.77 4.95-4.95 1.77zm12.72-12.72L16.59 7.41l-1.77 4.95-4.95-1.77 1.77-4.95 4.95 1.77z' },
]

const REVIEWS = [
  { nombre: 'María García', barrio: 'Pamplona Centro', stars: 5, fecha: 'hace 2 semanas', texto: 'Vinieron el mismo día que llamé. Mi lavadora Siemens quedó perfecta en menos de una hora. Muy profesionales, limpios y con precio justo.', destacada: true },
  { nombre: 'Carlos Tudela', barrio: 'Barañáin', stars: 5, fecha: 'hace 1 mes', texto: 'Repararon mi frigorífico Bosch sin problemas. Presupuesto sin compromiso y muy transparentes. El técnico muy amable.', destacada: false },
  { nombre: 'Ana Rekalde', barrio: 'Burlada', stars: 5, fecha: 'hace 3 semanas', texto: 'Excelente servicio. El lavavajillas lo arreglaron en la primera visita. Garantía de 3 meses incluida. Los tengo guardados para siempre.', destacada: true },
  { nombre: 'Javier Iriarte', barrio: 'Zizur Mayor', stars: 5, fecha: 'hace 2 meses', texto: 'Horno Balay reparado el mismo día. Precio muy razonable para lo que es. 100% recomendable.', destacada: false },
  { nombre: 'Laura Ollo', barrio: 'Villava', stars: 5, fecha: 'hace 1 semana', texto: 'La lavadora hacía un ruido horrible. Vinieron, diagnosticaron y repararon en 45 minutos. Trato genial y precio justo.', destacada: true },
  { nombre: 'Mikel Goñi', barrio: 'Ansoáin', stars: 4, fecha: 'hace 3 meses', texto: 'Buen servicio, vinieron puntuales y resolvieron el problema. Repetiría sin duda.', destacada: false },
]

const ZONAS = ['Pamplona','Barañáin','Burlada','Huarte','Villava','Ansoáin','Zizur Mayor','Berriozar','Cizur','Noáin','Sarriguren','Beriáin','Estella','Tudela']
---

<Layout>
<style>
  @keyframes float { 0%,100%{transform:translateY(0)} 50%{transform:translateY(-12px)} }
  @keyframes pulse-ring { 0%{transform:scale(1);opacity:.4} 100%{transform:scale(1.6);opacity:0} }
  @keyframes slide-up { from{opacity:0;transform:translateY(20px)} to{opacity:1;transform:translateY(0)} }

  .animate-float { animation: float 6s ease-in-out infinite; }
  .animate-pulse-ring::before {
    content:''; position:absolute; inset:0; border-radius:50%;
    background:inherit; animation:pulse-ring 2s ease-out infinite;
  }

  details summary::-webkit-details-marker { display:none; }
  details[open] .chevron { transform: rotate(180deg); }

  .service-card:hover .service-icon { transform: scale(1.1); }
  .service-card { transition: transform .2s, box-shadow .2s; }
  .service-card:hover { transform: translateY(-4px); box-shadow: 0 20px 40px rgba(0,0,0,.08); }

  .review-card { transition: box-shadow .2s; }
  .review-card:hover { box-shadow: 0 12px 32px rgba(0,0,0,.08); }

  .brand-card { transition: all .2s; }
  .brand-card:hover { transform: translateY(-2px); }
</style>

<!-- NAV -->
<header class="sticky top-0 z-50 bg-white/95 backdrop-blur-md border-b border-gray-100">
  <div class="max-w-6xl mx-auto px-5 py-4 flex items-center justify-between">
    <a href="/" class="flex items-center gap-3 group">
      <div class="w-10 h-10 bg-blue-700 rounded-2xl flex items-center justify-center shadow-sm group-hover:shadow-md transition-shadow">
        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"/>
        </svg>
      </div>
      <div class="leading-none">
        <span class="text-xl font-black text-blue-700 tracking-tight">DOMES</span><span class="text-xl font-black text-orange-500 tracking-tight">TECNIC</span>
        <div class="text-[10px] font-medium text-gray-400 mt-0.5 hidden sm:block tracking-widest uppercase">Pamplona · Navarra</div>
      </div>
    </a>
    <nav class="flex items-center gap-2">
      <a href={PHONE_HREF} class="hidden md:flex items-center gap-2 text-sm font-semibold text-gray-700 hover:text-blue-700 transition-colors px-3 py-2">
        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 13.6a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.61 3h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.91 10.6a16 16 0 0 0 6 6l.96-.96a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 21.66 18l.26-1.08z"/></svg>
        {PHONE}
      </a>
      <a href={WA_URL} target="_blank" rel="noopener" class="hidden sm:flex items-center gap-2 bg-green-500 hover:bg-green-600 text-white text-sm font-bold px-4 py-2 rounded-xl transition-colors shadow-sm">
        <svg width="15" height="15" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 0 0-3.48-8.413Z"/></svg>
        WhatsApp
      </a>
      <a href="#reserva" class="bg-orange-500 hover:bg-orange-600 text-white text-sm font-bold px-5 py-2.5 rounded-xl transition-colors shadow-sm">
        Reservar visita
      </a>
    </nav>
  </div>
</header>

<!-- HERO -->
<section class="relative overflow-hidden" style="background: linear-gradient(145deg, #020617 0%, #0f172a 40%, #1e3a8a 80%, #1d4ed8 100%); min-height: 92vh; display: flex; align-items: center;">
  <!-- Geometric shapes -->
  <div style="position:absolute;top:-200px;right:-200px;width:700px;height:700px;border-radius:50%;background:radial-gradient(circle,rgba(29,78,216,.25) 0%,transparent 70%);pointer-events:none;"></div>
  <div style="position:absolute;bottom:-150px;left:-150px;width:500px;height:500px;border-radius:50%;background:radial-gradient(circle,rgba(249,115,22,.15) 0%,transparent 70%);pointer-events:none;"></div>
  <!-- Grid pattern -->
  <div style="position:absolute;inset:0;background-image:linear-gradient(rgba(255,255,255,.03) 1px,transparent 1px),linear-gradient(90deg,rgba(255,255,255,.03) 1px,transparent 1px);background-size:64px 64px;pointer-events:none;"></div>

  <div class="relative max-w-6xl mx-auto px-5 py-24 w-full">
    <div class="grid lg:grid-cols-2 gap-16 items-center">
      <div>
        <!-- Availability badge -->
        <div class="inline-flex items-center gap-2.5 mb-8" style="background:rgba(255,255,255,.07);border:1px solid rgba(255,255,255,.12);border-radius:100px;padding:8px 18px;">
          <span style="width:8px;height:8px;background:#4ade80;border-radius:50%;display:inline-block;box-shadow:0 0 8px #4ade80;"></span>
          <span style="color:#93c5fd;font-size:14px;font-weight:600;letter-spacing:.02em;">Disponible hoy · Pamplona y Navarra</span>
        </div>

        <h1 style="font-size:clamp(2.5rem,5vw,3.75rem);font-weight:900;color:white;line-height:1.1;margin-bottom:1.5rem;letter-spacing:-.02em;">
          Tu electrodoméstico<br/>roto, <span style="color:#fb923c;">arreglado hoy.</span>
        </h1>

        <p style="font-size:1.125rem;color:#94a3b8;line-height:1.75;margin-bottom:2.5rem;max-width:480px;">
          Técnicos especializados en <strong style="color:white;font-weight:700;">Siemens, Bosch y Balay</strong>. Reparamos lavadoras, frigoríficos, hornos y más — en tu domicilio, el mismo día.
        </p>

        <div style="display:flex;flex-wrap:wrap;gap:12px;margin-bottom:2.5rem;">
          <a href="#reserva" style="display:inline-flex;align-items:center;gap:10px;background:#f97316;color:white;font-weight:700;padding:16px 28px;border-radius:14px;font-size:1rem;text-decoration:none;transition:all .2s;box-shadow:0 8px 24px rgba(249,115,22,.35);"
            onmouseover="this.style.background='#ea580c';this.style.transform='translateY(-2px)'"
            onmouseout="this.style.background='#f97316';this.style.transform='none'">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
            Reservar visita
          </a>
          <a href={PHONE_HREF} style="display:inline-flex;align-items:center;gap:10px;background:rgba(255,255,255,.08);border:1.5px solid rgba(255,255,255,.15);color:white;font-weight:600;padding:16px 28px;border-radius:14px;font-size:1rem;text-decoration:none;transition:all .2s;"
            onmouseover="this.style.background='rgba(255,255,255,.14)'"
            onmouseout="this.style.background='rgba(255,255,255,.08)'">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 13.6a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.61 3h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.91 10.6a16 16 0 0 0 6 6l.96-.96a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 21.66 18l.26-1.08z"/></svg>
            {PHONE}
          </a>
        </div>

        <div style="display:flex;flex-wrap:wrap;gap:20px;">
          {[
            ['Presupuesto gratuito', '#22c55e'],
            ['Garantía 3 meses', '#22c55e'],
            ['+500 reparaciones', '#22c55e'],
          ].map(([txt, color]) => (
            <span style={`display:inline-flex;align-items:center;gap:8px;color:#94a3b8;font-size:.875rem;font-weight:500;`}>
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke={color} stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
              {txt}
            </span>
          ))}
        </div>
      </div>

      <!-- Stats card -->
      <div style="display:grid;grid-template-columns:1fr 1fr;gap:16px;">
        {[
          { num: '4.9★', label: 'Valoración media', sub: '87 opiniones en Google' },
          { num: '+500', label: 'Reparaciones', sub: 'en Pamplona y Navarra' },
          { num: '90%', label: 'Primera visita', sub: 'resuelto en el momento' },
          { num: '3 meses', label: 'Garantía', sub: 'en piezas y mano de obra' },
        ].map(s => (
          <div style="background:rgba(255,255,255,.05);border:1px solid rgba(255,255,255,.1);border-radius:20px;padding:24px 20px;backdrop-filter:blur(8px);">
            <div style="font-size:1.75rem;font-weight:900;color:white;letter-spacing:-.02em;line-height:1;">{s.num}</div>
            <div style="color:#93c5fd;font-weight:700;font-size:.875rem;margin-top:8px;">{s.label}</div>
            <div style="color:#475569;font-size:.75rem;margin-top:4px;">{s.sub}</div>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>

<!-- TRUST BAR -->
<div style="background:#f97316;">
  <div class="max-w-6xl mx-auto px-5 py-3.5 flex flex-wrap items-center justify-center gap-6 sm:gap-10">
    {[
      ['Lun–Sáb · 8:00–20:00', 'M12 2a10 10 0 1 0 0 20A10 10 0 0 0 12 2zm.5 5v6l4 2-.7 1.2L11 14V7h1.5z'],
      ['Cita disponible hoy', 'M13 10V3L4 14h7v7l9-11h-7z'],
      ['Garantía incluida', 'M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z'],
      ['Visita a domicilio', 'M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z M9 22V12h6v10'],
    ].map(([txt, path]) => (
      <span style="display:inline-flex;align-items:center;gap:8px;color:white;font-size:.875rem;font-weight:700;">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d={path}/></svg>
        {txt}
      </span>
    ))}
  </div>
</div>

<!-- REVIEWS -->
<section style="padding:96px 0;background:#f8fafc;" id="opiniones">
  <div class="max-w-6xl mx-auto px-5">
    <div style="text-align:center;margin-bottom:48px;">
      <span style="color:#f97316;font-weight:700;font-size:.75rem;letter-spacing:.12em;text-transform:uppercase;">Opiniones verificadas de Google</span>
      <h2 style="font-size:clamp(1.75rem,4vw,2.5rem);font-weight:900;color:#0f172a;margin-top:12px;letter-spacing:-.02em;">Lo que dicen nuestros clientes</h2>
      <div style="display:flex;align-items:center;justify-content:center;gap:12px;margin-top:16px;">
        <div style="display:flex;gap:3px;">
          {[1,2,3,4,5].map(() => <svg width="22" height="22" viewBox="0 0 24 24" fill="#f59e0b" stroke="none"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>)}
        </div>
        <span style="font-size:2rem;font-weight:900;color:#0f172a;">4.9</span>
        <span style="color:#94a3b8;font-size:.875rem;">· 87 opiniones en Google</span>
      </div>
    </div>

    <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(300px,1fr));gap:20px;">
      {REVIEWS.map(r => (
        <article class="review-card" style={`background:white;border-radius:20px;padding:28px;border:1.5px solid ${r.destacada ? '#fed7aa' : '#f1f5f9'};`}>
          <div style="display:flex;justify-content:space-between;align-items:flex-start;margin-bottom:16px;">
            <div style="display:flex;align-items:center;gap:12px;">
              <div style="width:44px;height:44px;border-radius:50%;background:linear-gradient(135deg,#1d4ed8,#3b82f6);display:flex;align-items:center;justify-content:center;color:white;font-weight:800;font-size:.875rem;flex-shrink:0;">
                {r.nombre.split(' ').map((n: string) => n[0]).join('').slice(0,2)}
              </div>
              <div>
                <p style="font-weight:700;color:#0f172a;font-size:.9rem;">{r.nombre}</p>
                <p style="color:#94a3b8;font-size:.75rem;">{r.barrio}</p>
              </div>
            </div>
            <!-- Google G -->
            <svg width="20" height="20" viewBox="0 0 24 24"><path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" fill="#4285F4"/><path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/><path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z" fill="#FBBC05"/><path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"/></svg>
          </div>
          <div style="display:flex;gap:2px;margin-bottom:12px;">
            {[1,2,3,4,5].map(s => <svg width="14" height="14" viewBox="0 0 24 24" fill={s<=r.stars?'#f59e0b':'#e2e8f0'} stroke="none"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>)}
            <span style="color:#94a3b8;font-size:.7rem;margin-left:4px;align-self:center;">{r.fecha}</span>
          </div>
          <p style="color:#475569;font-size:.875rem;line-height:1.7;">"{r.texto}"</p>
        </article>
      ))}
    </div>

    <div style="text-align:center;margin-top:32px;">
      <a href="https://g.page/domestecnic" target="_blank" rel="noopener" style="color:#1d4ed8;font-weight:600;font-size:.875rem;text-decoration:none;display:inline-flex;align-items:center;gap:6px;">
        Ver todas las opiniones en Google
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
      </a>
    </div>
